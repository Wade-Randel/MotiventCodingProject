---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
---

<header>
  <div class="header-inner">

    <Image src={logo} alt="Northline Roofing & Gutters Logo" class="logo" />

    <button class="hamburger" aria-label="Toggle navigation" aria-expanded="false" aria-controls="nav-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="nav" id="nav-menu">
      <a href="/">Home</a>
      <a href="#services">Services</a>
      <a href="#process">Process</a>
      <a href="#faq">FAQ</a>
      <a href="#contact">Contact</a>
    </nav>
  </div>

</header>

<script>

  const hamburger = document.querySelector('.hamburger') as HTMLElement;
  const nav = document.querySelector('.nav') as HTMLElement;

  hamburger.addEventListener('click', () => {
    const isOpen = nav.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    hamburger.classList.toggle('is-open', isOpen);
  });

  //close menu when nav link is clicked
  document.querySelectorAll('.nav a').forEach(link => {
    link.addEventListener('click', () => {
      nav.classList.remove('is-open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.classList.remove('is-open');
    });
  });

</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 10;
    background-color: #2c2c2cb0;
    backdrop-filter: blur(6px);
    padding: 0 20px;
    box-sizing: border-box;
  }

  .header-inner {
    width: 100%;
    padding: 10px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    height: 75px;
    width: auto;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 21;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: #fff;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .hamburger.is-open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.is-open span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.is-open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  nav {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    flex-shrink: 0;
  }

  nav a {
    color: white;
    text-decoration: none;
    font-weight: bold;
    white-space: nowrap;
  }

  nav a:hover {
    text-decoration: underline;
    color: var(--color-accent-dark);
  }

  @media (max-width: 768px) {
    .logo {
      height: 45px;
      width: auto;
      padding-left: 0.5rem;
    }

    header {
      padding: 10px 8px;
      box-sizing: border-box;
    }

    .hamburger {
      display: flex;
      padding-right: 0.5rem;
    }

    nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      background-color: #1F2A38;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4.5rem;
      font-size: 3rem;
      z-index: 20;
      margin: 0;
      padding: 1rem;
      visibility: hidden;
      opacity: 0;
      transform: translateY(-10px);
      transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
    }

    nav.is-open {
      visibility: visible;
      opacity: 1;
      transform: translateY(0);
    }

    nav a:focus-visible {
      outline: 3px solid var(--color-accent-dark);
      outline-offset: 4px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hamburger span {
      transition: none;
    }
    nav {
      transition: none;
    }
  }

</style>