---
import ReviewCarousel from "./ReviewCarousel.jsx";
import { reviews } from "../data/reviews";
---

<section id="proof" class="proof">
    <div class="proof-inner">
        <div class="section-header">
            <p class="section-label">Trusted Locally</p>
            <h2>What Homeowners Say</h2>
            <p class="section-intro">
                4.9 average rating from 180+ local homeowners across North Texas.
            </p>
        </div>

        <ReviewCarousel client:visible reviews={reviews} />
    </div>
</section>

<style>
    .proof {
        background-color: #1F2A38;
        padding: 4rem 2rem;
        margin-left: auto;
        margin-right: auto;
        margin-bottom: 3rem;
        border-radius: 24px;
        max-width: 65%;
    }

    .proof-inner {
        max-width: 700px;
        margin: 0 auto;
        text-align: center;
    }

    .proof h2 {
        color: #fff;
        margin: 0;
    }

    :global(.review-carousel) {
        margin-top: 1rem;
    }

    :global(.review-card) {
        background-color: #2C3A4E;
        border: 1px solid #3A4A5E;
        border-radius: 10px;
        padding: 2rem;
        min-height: 160px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.75rem;
        opacity: 0;
        transition: opacity 0.5s ease; /* needs to CSS transition duration */
    }

    :global(.review-card.is-visible) {
        opacity: 1;
    }

    :global(.review-stars) {
        color: var(--color-accent-dark);
        font-size: 1.25rem;
    }

    :global(.review-comment) {
        color: #fff;
        font-size: 1.1rem;
        margin: 0;
    }

    :global(.review-author) {
        color: #c5cbd3;
        font-size: 0.9rem;
        margin: 0;
    }

    :global(.review-controls) {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-top: 1rem;
    }

    :global(.review-arrow) {
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: transparent;
        border: 2px solid #fff;
        color: #fff;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        font-size: 1.25rem;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

    :global(.review-arrow:hover) {
        background-color: #ffffff31;
    }

    :global(.review-arrow:focus-visible) {
        outline: 3px solid var(--color-accent-dark);
        outline-offset: 2px;
    }

    :global(.chevron) {
        display: block;
        width: 10px;
        height: 10px;
        border-style: solid;
        border-color: #fff;
        border-width: 0 2px 2px 0;
    }

    :global(.review-arrow-prev .chevron) {
        transform: rotate(135deg);
        margin-left: 5px; /* optical centering nudge */
    }

    :global(.review-arrow-next .chevron) {
        transform: rotate(-45deg);
        margin-right: 5px;
    }

    @media (max-width: 600px) {
        .proof {
            max-width: 100%;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        :global(.review-card) {
            opacity: 1;
            transform: none;
            transition: none;
        }
    }

</style>