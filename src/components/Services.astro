---
import ServiceCard from '../components/ServiceCard.astro';
import { services } from '../data/services.js';
---

<section id="services" class="services">
    <div class="services-inner">
        <div class="section-header">
            <p class="section-label">Services</p>
            <h2>What Do We Do?</h2>
            <p class="section-intro">
            From a quick storm check to a full roof replacement, we help North Texas homeowners handle the whole process, without the pressure.
            </p>
        </div>
        <div class="services-grid">
            {services.map(service => (
                <ServiceCard title={service.title} description={service.description} />
            ))}
        </div>
    </div>
</section>

<style>
    .services {
        position: relative;
        z-index: 1;
        margin-top: 26vh;
        margin-left: auto;
        margin-right: auto;
        margin-bottom: 3rem;
        border-radius: 24px;
        box-shadow: 0 -10px 10px rgba(0, 0, 0, 0.3);
        padding: 4rem 2rem;
        background-color: #1F2A38;
        max-width: 65%;
    }

    .services-inner {
        max-width: 1100px;
        margin: 0 auto;
        text-align: center;
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        text-align: left;
    }

    .services h2 {
        color: #fff;
        margin: 0;
    }

    @media (max-width: 600px) {
        .services {
            max-width: 100%;
            margin-top: 35vh;
            padding: 2rem 1rem;
        }

        .services-grid {
            grid-template-columns: 1fr;
        }
    }
</style>